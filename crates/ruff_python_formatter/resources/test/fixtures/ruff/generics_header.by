class Box[T]:
    value: T


class Pair[K, V]:
    key: K
    value: V


def identity[T](x: T) -> T:
    return x


class Constrained[T: (int, str)]: ...


# variance keywords: `out` covariant, `in` contravariant, `in out` invariant
class Variant[out Key, in Sent, in out Value]:
    key: Key
    value: Value


class BoundedVariant[out T: int = bool]: ...
