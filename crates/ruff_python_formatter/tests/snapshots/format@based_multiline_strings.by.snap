---
source: crates/ruff_python_formatter/tests/fixtures.rs
input_file: crates/ruff_python_formatter/resources/test/fixtures/ruff/based_multiline_strings.by
---
## Input
```bython
class A:
    text = """
asdf
"""

def f():
    x = """
hello
    world
"""
    return x

# top-level string
text = """
hello
world
"""

# nested scope
def outer():
    def inner():
        s = """
content
    indented
"""
        return s

# first line content should be preserved
x = """first line
second line
"""

# already correctly indented — should be idempotent
y = """
    already
    indented
    """
```

## Output
```bython
class A:
    text = """
        asdf
        """


def f():
    x = """
        hello
            world
        """
    return x


# top-level string
text = """
    hello
    world
    """


# nested scope
def outer():
    def inner():
        s = """
            content
                indented
            """
        return s


# first line content should be preserved
x = """first line
    second line
    """

# already correctly indented — should be idempotent
y = """
    already
    indented
    """
```
