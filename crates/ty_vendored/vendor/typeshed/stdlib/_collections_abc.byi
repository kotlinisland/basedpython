"""Abstract Base Classes (ABCs) for collections, according to PEP 3119.

Unit tests are in test_collections.
"""

import sys
from types import MappingProxyType
from typing import (  # noqa: Y022,Y038,UP035,Y057
    AbstractSet as Set,
    AsyncGenerator as AsyncGenerator,
    AsyncIterable as AsyncIterable,
    AsyncIterator as AsyncIterator,
    Awaitable as Awaitable,
    ByteString as ByteString,
    Callable as Callable,
    ClassVar,
    Collection as Collection,
    Container as Container,
    Coroutine as Coroutine,
    Generator as Generator,
    Generic,
    Hashable as Hashable,
    ItemsView as ItemsView,
    Iterable as Iterable,
    Iterator as Iterator,
    KeysView as KeysView,
    Mapping as Mapping,
    MappingView as MappingView,
    MutableMapping as MutableMapping,
    MutableSequence as MutableSequence,
    MutableSet as MutableSet,
    Protocol,
    Reversible as Reversible,
    Sequence as Sequence,
    Sized as Sized,
    TypeVar,
    ValuesView as ValuesView,
    final,
    runtime_checkable,
)

__all__ = [
    "Awaitable",
    "Coroutine",
    "AsyncIterable",
    "AsyncIterator",
    "AsyncGenerator",
    "Hashable",
    "Iterable",
    "Iterator",
    "Generator",
    "Reversible",
    "Sized",
    "Container",
    "Callable",
    "Collection",
    "Set",
    "MutableSet",
    "Mapping",
    "MutableMapping",
    "MappingView",
    "KeysView",
    "ItemsView",
    "ValuesView",
    "Sequence",
    "MutableSequence",
]
if sys.version_info < (3, 15):
    __all__ += ["ByteString"]
if sys.version_info >= (3, 12):
    __all__ += ["Buffer"]


final class dict_keys[out Key, out Value](KeysView[Key]):  # undocumented
    def __eq__(self, value: object, /) -> bool
    def __reversed__(self) -> Iterator[Key]:
        """Return a reverse iterator over the dict keys."""
    __hash__: ClassVar[None]  # type: ignore[assignment]
    if sys.version_info >= (3, 13):
        def isdisjoint(self, other: Iterable[Key], /) -> bool:
            """Return True if the view and the given iterable have a null intersection."""

    @property
    def mapping(self) -> MappingProxyType[Key, Value]:
        """dictionary that this view refers to"""

final class dict_values[out Key, out Value](ValuesView[Value]):  # undocumented
    def __reversed__(self) -> Iterator[Value]:
        """Return a reverse iterator over the dict values."""

    @property
    def mapping(self) -> MappingProxyType[Key, Value]:
        """dictionary that this view refers to"""

final class dict_items[out Key, out Value](ItemsView[Key, Value]):  # undocumented
    def __eq__(self, value: object, /) -> bool
    def __reversed__(self) -> Iterator[(Key, Value)]:
        """Return a reverse iterator over the dict items."""
    __hash__: ClassVar[None]  # type: ignore[assignment]
    if sys.version_info >= (3, 13):
        def isdisjoint(self, other: Iterable[(Key, Value)], /) -> bool:
            """Return True if the view and the given iterable have a null intersection."""

    @property
    def mapping(self) -> MappingProxyType[Key, Value]:
        """dictionary that this view refers to"""

if sys.version_info >= (3, 12):
    @runtime_checkable
    class Buffer(Protocol):
        __slots__ = ()
        abstract def __buffer__(self, flags: int, /) -> memoryview
