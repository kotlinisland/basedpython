import sys
from collections.abc import Awaitable, Callable, Coroutine
from typing import Any, ParamSpec, TypeGuard, TypeVar
from typing_extensions import deprecated

# Keep asyncio.__all__ updated with any changes to __all__ here
if sys.version_info >= (3, 11):
    __all__ = ("iscoroutinefunction", "iscoroutine")
else:
    __all__ = ("coroutine", "iscoroutinefunction", "iscoroutine")


if sys.version_info < (3, 11):
    @deprecated("Deprecated since Python 3.8; removed in Python 3.11. Use `async def` instead.")
    def coroutine[FunctionT: Callable[..., Any]](func: FunctionT) -> FunctionT:
        """Decorator to mark coroutines.

        If the coroutine is not yielded from before it is destroyed,
        an error message is logged.
        """

def iscoroutine(obj: object) -> obj is Coroutine[Any, Any, Any]:
    """Return True if obj is a coroutine object."""

if sys.version_info >= (3, 11):
    @deprecated("Deprecated since Python 3.14. Use `inspect.iscoroutinefunction()` instead.")
    def iscoroutinefunction(func: (...) -> Coroutine[Any, Any, Any]) -> bool:
        """Return True if func is a decorated coroutine function."""
    @deprecated("Deprecated since Python 3.14. Use `inspect.iscoroutinefunction()` instead.")
    def iscoroutinefunction[**P, Element](func: Callable[P, Awaitable[Element]]) -> TypeGuard[Callable[P, Coroutine[Any, Any, Element]]]
    @deprecated("Deprecated since Python 3.14. Use `inspect.iscoroutinefunction()` instead.")
    def iscoroutinefunction[**P](func: Callable[P, object]) -> TypeGuard[Callable[P, Coroutine[Any, Any, Any]]]
    @deprecated("Deprecated since Python 3.14. Use `inspect.iscoroutinefunction()` instead.")
    def iscoroutinefunction(func: object) -> TypeGuard[(...) -> Coroutine[Any, Any, Any]]
else:
    # Sometimes needed in Python < 3.11 due to the fact that it supports @coroutine
    # which was removed in 3.11 which the inspect version doesn't support.
    def iscoroutinefunction(func: (...) -> Coroutine[Any, Any, Any]) -> bool:
        """Return True if func is a decorated coroutine function."""
    def iscoroutinefunction[**P, Element](func: Callable[P, Awaitable[Element]]) -> TypeGuard[Callable[P, Coroutine[Any, Any, Element]]]
    def iscoroutinefunction[**P](func: Callable[P, object]) -> TypeGuard[Callable[P, Coroutine[Any, Any, Any]]]
    def iscoroutinefunction(func: object) -> TypeGuard[(...) -> Coroutine[Any, Any, Any]]
