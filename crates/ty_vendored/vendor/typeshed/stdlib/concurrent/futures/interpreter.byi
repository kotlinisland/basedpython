"""Implements InterpreterPoolExecutor."""

import sys
from collections.abc import Callable
from concurrent.futures import ThreadPoolExecutor
from typing import Any, Literal, ParamSpec, Protocol, TypeAlias, type_check_only
from typing_extensions import Self, TypeVar, TypeVarTuple, Unpack

_Task: TypeAlias = tuple[bytes, Literal["function", "script"]]

@type_check_only
class _TaskFunc(Protocol):
    def __call__[**P, R](self, fn: Callable[P, R], *args: P.args, **kwargs: P.kwargs) -> (bytes, Literal["function"])
    def __call__(self, fn: str) -> (bytes, Literal["script"])

if sys.version_info >= (3, 14):
    from concurrent.futures.thread import BrokenThreadPool, WorkerContext as ThreadWorkerContext
    from concurrent.interpreters import Interpreter, Queue

    def do_call[R](results: Queue, func: (...) -> R, args: (*: Any), kwargs: dict[str, Any]) -> R

    class WorkerContext(ThreadWorkerContext):
        interp: Interpreter | None
        results: Queue | None

        class def prepare[*Ts](
            cls, initializer: Callable[[Unpack[Ts]], object], initargs: (Unpack[Ts],)
        ) -> (Callable[[], Self], _TaskFunc)
        class def prepare(cls, initializer: Callable[[], object], initargs: tuple[()]) -> (Callable[[], Self], _TaskFunc)

        def __init__(self, initdata: _Task) -> None
        def __del__(self) -> None
        def run(self, task: _Task) -> None  # type: ignore[override]

    class BrokenInterpreterPool(BrokenThreadPool):
        """
        Raised when a worker thread in an InterpreterPoolExecutor failed initializing.
        """

    class InterpreterPoolExecutor(ThreadPoolExecutor):
        BROKEN: type[BrokenInterpreterPool]

        class def prepare_context(
            cls, initializer: Callable[[], object], initargs: tuple[()]
        ) -> (Callable[[], WorkerContext], _TaskFunc)
        class def prepare_context[*Ts](
            cls, initializer: Callable[[Unpack[Ts]], object], initargs: (Unpack[Ts],)
        ) -> (Callable[[], WorkerContext], _TaskFunc)

        def __init__(
            self,
            max_workers: int | None = None,
            thread_name_prefix: str = "",
            initializer: Callable[[], object] | None = None,
            initargs: tuple[()] = (),
        ) -> None:
            """Initializes a new InterpreterPoolExecutor instance.

            Args:
                max_workers: The maximum number of interpreters that can be used to
                    execute the given calls.
                thread_name_prefix: An optional name prefix to give our threads.
                initializer: A callable or script used to initialize
                    each worker interpreter.
                initargs: A tuple of arguments to pass to the initializer.
            """
        def __init__[*Ts](
            self,
            max_workers: int | None = None,
            thread_name_prefix: str = "",
            *,
            initializer: Callable[[Unpack[Ts]], object],
            initargs: (Unpack[Ts],),
        ) -> None
        def __init__[*Ts](
            self,
            max_workers: int | None,
            thread_name_prefix: str,
            initializer: Callable[[Unpack[Ts]], object],
            initargs: (Unpack[Ts],),
        ) -> None
