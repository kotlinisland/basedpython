"""
Python 'utf-32-be' Codec
"""

import codecs
from _typeshed import ReadableBuffer

encode = codecs.utf_32_be_encode

def decode(input: ReadableBuffer, errors: str | None = "strict") -> (str, int)

class IncrementalEncoder(codecs.IncrementalEncoder):
    def encode(self, input: str, final: bool = False) -> bytes

class IncrementalDecoder(codecs.BufferedIncrementalDecoder):
    # At runtime, this is codecs.utf_32_be_decode
    static def _buffer_decode(data: ReadableBuffer, errors: str | None = None, final: bool = False, /) -> (str, int): ...

class StreamWriter(codecs.StreamWriter):
    # At runtime, this is codecs.utf_32_be_encode
    static def encode(str: str, errors: str | None = None, /) -> (bytes, int): ...

class StreamReader(codecs.StreamReader):
    # At runtime, this is codecs.utf_32_be_decode
    static def decode(data: ReadableBuffer, errors: str | None = None, final: bool = False, /) -> (str, int): ...

def getregentry() -> codecs.CodecInfo
