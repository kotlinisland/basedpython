"""functools.py - Tools for working with functions and callable objects"""

import sys
import types
from _typeshed import SupportsAllComparisons, SupportsItems
from collections.abc import Callable, Hashable, Iterable, Sized
from types import GenericAlias
from typing import Any, Final, Generic, Literal, NamedTuple, ParamSpec, TypeAlias, TypedDict, TypeVar, final, type_check_only
from typing_extensions import Self, disjoint_base

__all__ = [
    "update_wrapper",
    "wraps",
    "WRAPPER_ASSIGNMENTS",
    "WRAPPER_UPDATES",
    "total_ordering",
    "cmp_to_key",
    "lru_cache",
    "reduce",
    "partial",
    "partialmethod",
    "singledispatch",
    "cached_property",
    "singledispatchmethod",
    "cache",
]


if sys.version_info >= (3, 14):
    def reduce[Element, Other](function: Callable[[Element, Other], Element], iterable: Iterable[Other], /, initial: Element) -> Element:
        """Apply a function of two arguments cumulatively to the items of an iterable, from left to right.

        This effectively reduces the iterable to a single value.  If initial is present,
        it is placed before the items of the iterable in the calculation, and serves as
        a default when the iterable is empty.

        For example, reduce(lambda x, y: x+y, [1, 2, 3, 4, 5])
        calculates ((((1 + 2) + 3) + 4) + 5).
        """
else:
    def reduce[Element, Other](function: Callable[[Element, Other], Element], iterable: Iterable[Other], initial: Element, /) -> Element:
        """reduce(function, iterable[, initial], /) -> value

        Apply a function of two arguments cumulatively to the items of an iterable, from left to right.

        This effectively reduces the iterable to a single value.  If initial is present,
        it is placed before the items of the iterable in the calculation, and serves as
        a default when the iterable is empty.

        For example, reduce(lambda x, y: x+y, [1, 2, 3, 4, 5])
        calculates ((((1 + 2) + 3) + 4) + 5).
        """

def reduce[Element](function: Callable[[Element, Element], Element], iterable: Iterable[Element], /) -> Element:
    """Apply a function of two arguments cumulatively to the items of an iterable, from left to right.

    This effectively reduces the iterable to a single value.  If initial is present,
    it is placed before the items of the iterable in the calculation, and serves as
    a default when the iterable is empty.

    For example, reduce(lambda x, y: x+y, [1, 2, 3, 4, 5])
    calculates ((((1 + 2) + 3) + 4) + 5).
    """

class _CacheInfo(NamedTuple):
    """CacheInfo(hits, misses, maxsize, currsize)"""

    hits: int
    misses: int
    maxsize: int | None
    currsize: int

@type_check_only
class _CacheParameters(TypedDict):
    maxsize: int
    typed: bool

final class _lru_cache_wrapper[out Element]:
    """Create a cached callable that wraps another function.

    user_function:      the function being cached

    maxsize:  0         for no caching
              None      for unlimited cache size
              n         for a bounded cache

    typed:    False     cache f(3) and f(3.0) as identical calls
              True      cache f(3) and f(3.0) as distinct calls

    cache_info_type:    namedtuple class with the fields:
                            hits misses currsize maxsize
    """

    __wrapped__: (...) -> Element
    def __call__(self, *args: Hashable, **kwargs: Hashable) -> Element:
        """Call self as a function."""

    def cache_info(self) -> _CacheInfo:
        """Report cache statistics"""

    def cache_clear(self) -> None:
        """Clear the cache and cache statistics"""

    def cache_parameters(self) -> _CacheParameters
    def __copy__(self) -> _lru_cache_wrapper[Element]
    def __deepcopy__(self, memo: Any, /) -> _lru_cache_wrapper[Element]

    # as with ``Callable``, we'll assume that these attributes exist
    __name__: str
    __qualname__: str

def lru_cache[Element](maxsize: int | None = 128, typed: bool = False) -> Callable[[(...) -> Element], _lru_cache_wrapper[Element]]:
    """Least-recently-used cache decorator.

    If *maxsize* is set to None, the LRU features are disabled and the cache
    can grow without bound.

    If *typed* is True, arguments of different types will be cached separately.
    For example, f(decimal.Decimal("3.0")) and f(3.0) will be treated as
    distinct calls with distinct results. Some types such as str and int may
    be cached separately even when typed is false.

    Arguments to the cached function must be hashable.

    View the cache statistics named tuple (hits, misses, maxsize, currsize)
    with f.cache_info().  Clear the cache and statistics with f.cache_clear().
    Access the underlying function with f.__wrapped__.

    See:  https://en.wikipedia.org/wiki/Cache_replacement_policies#Least_recently_used_(LRU)

    """
def lru_cache[Element](maxsize: (...) -> Element, typed: bool = False) -> _lru_cache_wrapper[Element]

if sys.version_info >= (3, 14):
    WRAPPER_ASSIGNMENTS: Final[(Literal["__module__"], Literal["__name__"], Literal["__qualname__"], Literal["__doc__"], Literal["__annotate__"], Literal["__type_params__"])]
elif sys.version_info >= (3, 12):
    WRAPPER_ASSIGNMENTS: Final[(Literal["__module__"], Literal["__name__"], Literal["__qualname__"], Literal["__doc__"], Literal["__annotations__"], Literal["__type_params__"])]
else:
    WRAPPER_ASSIGNMENTS: Final[(Literal["__module__"], Literal["__name__"], Literal["__qualname__"], Literal["__doc__"], Literal["__annotations__"])]

WRAPPER_UPDATES: Final[(Literal["__dict__"],)]

@type_check_only
class _Wrapped[**PWrapped, in out RWrapped, **PWrapper, in out RWrapper]:
    __wrapped__: Callable[PWrapped, RWrapped]
    def __call__(self, *args: PWrapper.args, **kwargs: PWrapper.kwargs) -> RWrapper
    # as with ``Callable``, we'll assume that these attributes exist
    __name__: str
    __qualname__: str

@type_check_only
class _Wrapper[**PWrapped, in out RWrapped]:
    def __call__[**PWrapper, RWrapper](self, f: Callable[PWrapper, RWrapper]) -> _Wrapped[PWrapped, RWrapped, PWrapper, RWrapper]

if sys.version_info >= (3, 14):
    def update_wrapper[**PWrapper, RWrapper, **PWrapped, RWrapped](
        wrapper: Callable[PWrapper, RWrapper],
        wrapped: Callable[PWrapped, RWrapped],
        assigned: Iterable[str] = ("__module__", "__name__", "__qualname__", "__doc__", "__annotate__", "__type_params__"),
        updated: Iterable[str] = ("__dict__",),
    ) -> _Wrapped[PWrapped, RWrapped, PWrapper, RWrapper]:
        """Update a wrapper function to look like the wrapped function

        wrapper is the function to be updated
        wrapped is the original function
        assigned is a tuple naming the attributes assigned directly
        from the wrapped function to the wrapper function (defaults to
        functools.WRAPPER_ASSIGNMENTS)
        updated is a tuple naming the attributes of the wrapper that
        are updated with the corresponding attribute from the wrapped
        function (defaults to functools.WRAPPER_UPDATES)
        """

    def wraps[**PWrapped, RWrapped](
        wrapped: Callable[PWrapped, RWrapped],
        assigned: Iterable[str] = ("__module__", "__name__", "__qualname__", "__doc__", "__annotate__", "__type_params__"),
        updated: Iterable[str] = ("__dict__",),
    ) -> _Wrapper[PWrapped, RWrapped]:
        """Decorator factory to apply update_wrapper() to a wrapper function

        Returns a decorator that invokes update_wrapper() with the decorated
        function as the wrapper argument and the arguments to wraps() as the
        remaining arguments. Default arguments are as for update_wrapper().
        This is a convenience function to simplify applying partial() to
        update_wrapper().
        """

elif sys.version_info >= (3, 12):
    def update_wrapper[**PWrapper, RWrapper, **PWrapped, RWrapped](
        wrapper: Callable[PWrapper, RWrapper],
        wrapped: Callable[PWrapped, RWrapped],
        assigned: Iterable[str] = ("__module__", "__name__", "__qualname__", "__doc__", "__annotations__", "__type_params__"),
        updated: Iterable[str] = ("__dict__",),
    ) -> _Wrapped[PWrapped, RWrapped, PWrapper, RWrapper]:
        """Update a wrapper function to look like the wrapped function

        wrapper is the function to be updated
        wrapped is the original function
        assigned is a tuple naming the attributes assigned directly
        from the wrapped function to the wrapper function (defaults to
        functools.WRAPPER_ASSIGNMENTS)
        updated is a tuple naming the attributes of the wrapper that
        are updated with the corresponding attribute from the wrapped
        function (defaults to functools.WRAPPER_UPDATES)
        """

    def wraps[**PWrapped, RWrapped](
        wrapped: Callable[PWrapped, RWrapped],
        assigned: Iterable[str] = ("__module__", "__name__", "__qualname__", "__doc__", "__annotations__", "__type_params__"),
        updated: Iterable[str] = ("__dict__",),
    ) -> _Wrapper[PWrapped, RWrapped]:
        """Decorator factory to apply update_wrapper() to a wrapper function

        Returns a decorator that invokes update_wrapper() with the decorated
        function as the wrapper argument and the arguments to wraps() as the
        remaining arguments. Default arguments are as for update_wrapper().
        This is a convenience function to simplify applying partial() to
        update_wrapper().
        """

else:
    def update_wrapper[**PWrapper, RWrapper, **PWrapped, RWrapped](
        wrapper: Callable[PWrapper, RWrapper],
        wrapped: Callable[PWrapped, RWrapped],
        assigned: Iterable[str] = ("__module__", "__name__", "__qualname__", "__doc__", "__annotations__"),
        updated: Iterable[str] = ("__dict__",),
    ) -> _Wrapped[PWrapped, RWrapped, PWrapper, RWrapper]:
        """Update a wrapper function to look like the wrapped function

        wrapper is the function to be updated
        wrapped is the original function
        assigned is a tuple naming the attributes assigned directly
        from the wrapped function to the wrapper function (defaults to
        functools.WRAPPER_ASSIGNMENTS)
        updated is a tuple naming the attributes of the wrapper that
        are updated with the corresponding attribute from the wrapped
        function (defaults to functools.WRAPPER_UPDATES)
        """

    def wraps[**PWrapped, RWrapped](
        wrapped: Callable[PWrapped, RWrapped],
        assigned: Iterable[str] = ("__module__", "__name__", "__qualname__", "__doc__", "__annotations__"),
        updated: Iterable[str] = ("__dict__",),
    ) -> _Wrapper[PWrapped, RWrapped]:
        """Decorator factory to apply update_wrapper() to a wrapper function

        Returns a decorator that invokes update_wrapper() with the decorated
        function as the wrapper argument and the arguments to wraps() as the
        remaining arguments. Default arguments are as for update_wrapper().
        This is a convenience function to simplify applying partial() to
        update_wrapper().
        """

def total_ordering[Element](cls: type[Element]) -> type[Element]:
    """Class decorator that fills in missing ordering methods"""

def cmp_to_key[Element](mycmp: Callable[[Element, Element], int]) -> Callable[[Element], SupportsAllComparisons]:
    """Convert a cmp= function into a key= function.

    mycmp
      Function that compares two objects.
    """

@disjoint_base
class partial[in out Element]:
    """Create a new function with partial application of the given arguments
    and keywords.
    """

    @property
    def func(self) -> (...) -> Element:
        """function object to use in future partial calls"""

    @property
    def args(self) -> (*: Any):
        """tuple of arguments to future partial calls"""

    @property
    def keywords(self) -> dict[str, Any]:
        """dictionary of keyword arguments to future partial calls"""

    def __new__(cls, func: (...) -> Element, /, *args: Any, **kwargs: Any) -> Self
    def __call__(self, /, *args: Any, **kwargs: Any) -> Element:
        """Call self as a function."""

    def __class_getitem__(cls, item: Any, /) -> GenericAlias:
        """See PEP 585"""

# With protocols, this could change into a generic protocol that defines __get__ and returns _T
_Descriptor: TypeAlias = Any

class partialmethod[in out Element]:
    """Method descriptor with partial application of the given arguments
    and keywords.

    Supports wrapping existing descriptors and handles non-descriptor
    callables as instance methods.
    """

    func: (...) -> Element | _Descriptor
    args: (*: Any)
    keywords: dict[str, Any]
    if sys.version_info >= (3, 14):
        def __new__(self, func: (...) -> Element, /, *args: Any, **keywords: Any) -> Self
        def __new__(self, func: _Descriptor, /, *args: Any, **keywords: Any) -> Self
    else:
        def __init__(self, func: (...) -> Element, /, *args: Any, **keywords: Any) -> None
        def __init__(self, func: _Descriptor, /, *args: Any, **keywords: Any) -> None

    def __get__(self, obj: Any, cls: type[Any] | None = None) -> (...) -> Element
    @property
    def __isabstractmethod__(self) -> bool
    def __class_getitem__(cls, item: Any, /) -> GenericAlias:
        """Represent a PEP 585 generic type

        E.g. for t = list[int], t.__origin__ is list and t.__args__ is (int,).
        """

if sys.version_info >= (3, 11):
    _RegType: TypeAlias = type[Any] | types.UnionType
else:
    _RegType: TypeAlias = type[Any]

@type_check_only
class _SingleDispatchCallable[in out Element]:
    registry: types.MappingProxyType[Any, (...) -> Element]
    def dispatch(self, cls: Any) -> (...) -> Element

    # @fun.register(complex)
    # def _(arg, verbose=False): ...
    def register(self, cls: _RegType, func: None = None) -> Callable[[(...) -> Element], (...) -> Element]
    # @fun.register
    # def _(arg: int, verbose=False):
    def register(self, cls: (...) -> Element, func: None = None) -> (...) -> Element
    # fun.register(int, lambda x: x)
    def register(self, cls: _RegType, func: (...) -> Element) -> (...) -> Element

    def _clear_cache(self) -> None
    def __call__(self, /, *args: Any, **kwargs: Any) -> Element

def singledispatch[Element](func: (...) -> Element) -> _SingleDispatchCallable[Element]:
    """Single-dispatch generic function decorator.

    Transforms a function into a generic function, which can have different
    behaviours depending upon the type of its first argument. The decorated
    function acts as the default implementation, and additional
    implementations can be registered using the register() attribute of the
    generic function.
    """

class singledispatchmethod[in out Element]:
    """Single-dispatch generic method descriptor.

    Supports wrapping existing descriptors.
    """

    dispatcher: _SingleDispatchCallable[Element]
    func: (...) -> Element
    def __init__(self, func: (...) -> Element) -> None
    @property
    def __isabstractmethod__(self) -> bool

    def register(self, cls: _RegType, method: None = None) -> Callable[[(...) -> Element], (...) -> Element]:
        """generic_method.register(cls, func) -> func

        Registers a new implementation for the given *cls* on a *generic_method*.
        """
    def register(self, cls: (...) -> Element, method: None = None) -> (...) -> Element
    def register(self, cls: _RegType, method: (...) -> Element) -> (...) -> Element

    def __get__[Other](self, obj: Other, cls: type[Other] | None = None) -> (...) -> Element

class cached_property[out Element]:
    func: Callable[[Any], Element]
    attrname: str | None
    def __init__(self, func: Callable[[Any], Element]) -> None

    def __get__(self, instance: None, owner: type[Any] | None = None) -> Self
    def __get__(self, instance: object, owner: type[Any] | None = None) -> Element

    def __set_name__(self, owner: type[Any], name: str) -> None
    # __set__ is not defined at runtime, but @cached_property is designed to be settable
    def __set__(self, instance: object, value: Element) -> None  # type: ignore[misc]  # pyright: ignore[reportGeneralTypeIssues]
    def __class_getitem__(cls, item: Any, /) -> GenericAlias:
        """Represent a PEP 585 generic type

        E.g. for t = list[int], t.__origin__ is list and t.__args__ is (int,).
        """

def cache[Element](user_function: (...) -> Element, /) -> _lru_cache_wrapper[Element]:
    """Simple lightweight unbounded cache.  Sometimes called "memoize"."""

def _make_key(
    args: (*: Hashable),
    kwds: SupportsItems[Any, Any],
    typed: bool,
    kwd_mark: (*: object) = ...,
    fasttypes: set[type] = ...,
    tuple: type = ...,
    type: Any = ...,
    len: Callable[[Sized], int] = ...,
) -> Hashable:
    """Make a cache key from optionally typed positional and keyword arguments

    The key is constructed in a way that is flat as possible rather than
    as a nested structure that would take more memory.

    If there is only a single argument and its data type is known to cache
    its hash value, then that argument is returned without a wrapper.  This
    saves space and improves lookup speed.

    """

if sys.version_info >= (3, 14):
    final class _PlaceholderType:
        """The type of the Placeholder singleton.

        Used as a placeholder for partial arguments.
        """

    Placeholder: Final[_PlaceholderType]

    __all__ += ["Placeholder"]
