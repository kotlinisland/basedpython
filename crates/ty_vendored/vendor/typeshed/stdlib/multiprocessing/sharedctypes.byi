import ctypes
from _ctypes import _CData
from collections.abc import Callable, Iterable, Sequence
from ctypes import _SimpleCData, c_char
from multiprocessing.context import BaseContext
from multiprocessing.synchronize import _LockLike
from types import TracebackType
from typing import Any, Generic, Literal, Protocol, SupportsIndex, TypeVar, type_check_only

__all__ = ["RawValue", "RawArray", "Value", "Array", "copy", "synchronized"]


def RawValue[CT: _CData](typecode_or_type: type[CT], *args: Any) -> CT:
    """
    Returns a ctypes object allocated from shared memory
    """
def RawValue(typecode_or_type: str, *args: Any) -> Any

def RawArray[CT: _CData](typecode_or_type: type[CT], size_or_initializer: int | Sequence[Any]) -> ctypes.Array[CT]:
    """
    Returns a ctypes array allocated from shared memory
    """
def RawArray(typecode_or_type: str, size_or_initializer: int | Sequence[Any]) -> Any

def Value[CT: _CData](typecode_or_type: type[CT], *args: Any, lock: Literal[False], ctx: BaseContext | None = None) -> CT:
    """
    Return a synchronization wrapper for a Value
    """
def Value[CT: _CData](
    typecode_or_type: type[CT], *args: Any, lock: Literal[True] | _LockLike = True, ctx: BaseContext | None = None
) -> SynchronizedBase[CT]
def Value(
    typecode_or_type: str, *args: Any, lock: Literal[True] | _LockLike = True, ctx: BaseContext | None = None
) -> SynchronizedBase[Any]
def Value(
    typecode_or_type: str | type[_CData], *args: Any, lock: bool | _LockLike = True, ctx: BaseContext | None = None
) -> Any

def Array[CT: _CData](
    typecode_or_type: type[CT], size_or_initializer: int | Sequence[Any], *, lock: Literal[False], ctx: BaseContext | None = None
) -> CT:
    """
    Return a synchronization wrapper for a RawArray
    """
def Array(
    typecode_or_type: type[c_char],
    size_or_initializer: int | Sequence[Any],
    *,
    lock: Literal[True] | _LockLike = True,
    ctx: BaseContext | None = None,
) -> SynchronizedString
def Array[Element](
    typecode_or_type: type[_SimpleCData[Element]],
    size_or_initializer: int | Sequence[Any],
    *,
    lock: Literal[True] | _LockLike = True,
    ctx: BaseContext | None = None,
) -> SynchronizedArray[Element]
def Array(
    typecode_or_type: str,
    size_or_initializer: int | Sequence[Any],
    *,
    lock: Literal[True] | _LockLike = True,
    ctx: BaseContext | None = None,
) -> SynchronizedArray[Any]
def Array(
    typecode_or_type: str | type[_CData],
    size_or_initializer: int | Sequence[Any],
    *,
    lock: bool | _LockLike = True,
    ctx: BaseContext | None = None,
) -> Any

def copy[CT: _CData](obj: CT) -> CT

def synchronized[Element](obj: _SimpleCData[Element], lock: _LockLike | None = None, ctx: Any | None = None) -> Synchronized[Element]
def synchronized(obj: ctypes.Array[c_char], lock: _LockLike | None = None, ctx: Any | None = None) -> SynchronizedString
def synchronized[Element](
    obj: ctypes.Array[_SimpleCData[Element]], lock: _LockLike | None = None, ctx: Any | None = None
) -> SynchronizedArray[Element]
def synchronized[CT: _CData](obj: CT, lock: _LockLike | None = None, ctx: Any | None = None) -> SynchronizedBase[CT]

@type_check_only
class _AcquireFunc(Protocol):
    def __call__(self, block: bool = ..., timeout: float | None = ..., /) -> bool

class SynchronizedBase[in out CT: _CData]:
    acquire: _AcquireFunc
    release: Callable[[], None]
    def __init__(self, obj: Any, lock: _LockLike | None = None, ctx: Any | None = None) -> None
    def __reduce__(self) -> (Callable[[Any, _LockLike], SynchronizedBase[Any]], (Any, _LockLike))
    def get_obj(self) -> CT
    def get_lock(self) -> _LockLike
    def __enter__(self) -> bool
    def __exit__(
        self, exc_type: type[BaseException] | None, exc_val: BaseException | None, exc_tb: TracebackType | None, /
    ) -> None

class Synchronized[in out Element](SynchronizedBase[_SimpleCData[Element]]):
    value: Element

class SynchronizedArray[in out Element](SynchronizedBase[ctypes.Array[_SimpleCData[Element]]]):
    def __len__(self) -> int

    def __getitem__(self, i: slice[SupportsIndex | None]) -> list[Element]
    def __getitem__(self, i: SupportsIndex) -> Element

    def __setitem__(self, i: slice[SupportsIndex | None], value: Iterable[Element]) -> None
    def __setitem__(self, i: SupportsIndex, value: Element) -> None

    def __getslice__(self, start: SupportsIndex, stop: SupportsIndex) -> list[Element]
    def __setslice__(self, start: SupportsIndex, stop: SupportsIndex, values: Iterable[Element]) -> None

class SynchronizedString(SynchronizedArray[bytes]):
    def __getitem__(self, i: slice[SupportsIndex | None]) -> bytes
    def __getitem__(self, i: SupportsIndex) -> bytes

    def __setitem__(self, i: slice[SupportsIndex | None], value: bytes) -> None
    def __setitem__(self, i: SupportsIndex, value: bytes) -> None

    def __getslice__(self, start: SupportsIndex, stop: SupportsIndex) -> bytes  # type: ignore[override]
    def __setslice__(self, start: SupportsIndex, stop: SupportsIndex, values: bytes) -> None  # type: ignore[override]

    value: bytes
    raw: bytes
