"""Python version compatibility support for minidom.

This module contains internal implementation details and
should not be imported; use xml.dom.minidom instead.
"""

from collections.abc import Iterable
from typing import Any, Literal, TypeVar

__all__ = ["NodeList", "EmptyNodeList", "StringTypes", "defproperty"]


StringTypes: (type[str],)

class NodeList[in out Element](list[Element]):
    __slots__ = ()
    @property
    def length(self) -> int:
        """The number of nodes in the NodeList."""

    def item(self, index: int) -> Element | None

class EmptyNodeList(tuple[()]):
    __slots__ = ()
    @property
    def length(self) -> Literal[0]:
        """The number of nodes in the NodeList."""

    def item(self, index: int) -> None
    def __add__[Element](self, other: Iterable[Element]) -> NodeList[Element]  # type: ignore[override]
    def __radd__[Element](self, other: Iterable[Element]) -> NodeList[Element]

def defproperty(klass: type[Any], name: str, doc: str) -> None
